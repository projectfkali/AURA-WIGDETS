      "htmlContent": "<style>body{margin:0;overflow:hidden;background:#000}canvas{display:block}</style><canvas id=\"c\"></canvas><script>const c=document.getElementById(\"c\"),ctx=c.getContext(\"2d\");c.width=window.innerWidth;c.height=window.innerHeight;const letters=\"0123456789ABCDEF\".split(\"\");const fontSize=16,columns=c.width/fontSize;const drops=[];for(let x=0;x<columns;x++)drops[x]=1;setInterval(()=>{ctx.fillStyle=\"rgba(0,0,0,0.05)\";ctx.fillRect(0,0,c.width,c.height);ctx.fillStyle=\"#0F0\";ctx.font=fontSize+\"px arial\";for(let i=0;i<drops.length;i++){const text=letters[Math.floor(Math.random()*letters.length)];ctx.fillText(text,i*fontSize,drops[i]*fontSize);if(drops[i]*fontSize>c.height&&Math.random()>0.975)drops[i]=0;drops[i]++}},33);</script>"
